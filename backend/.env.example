# --- Database ---
# Local dev (SQLite, zero setup):
DATABASE_URL="file:./dev.db"
# Production (Postgres, e.g. Render/Railway/Supabase) - swap provider in schema.prisma to "postgresql":
# DATABASE_URL="postgresql://user:password@host:5432/dbname"

# --- Auth ---
JWT_SECRET="replace_this_with_a_long_random_secret"
JWT_EXPIRES_IN="7d"

# --- Server ---
PORT=5000
CLIENT_URL="http://localhost:5173"

# --- Overdue detection default (days) ---
OVERDUE_THRESHOLD_DAYS=3

# --- Photo Upload ---
# UPLOAD_STRATEGY = "local" (default, saves to /uploads folder, no external account needed)
#                 = "cloudinary" (production-ready, requires Cloudinary free account)
UPLOAD_STRATEGY="local"
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Email ---
# EMAIL_STRATEGY = "console" (default, just logs emails to terminal, no setup needed for local dev)
#                = "smtp" (real emails via Gmail SMTP or any provider)
EMAIL_STRATEGY="console"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Society Admin <no-reply@society.com>"
